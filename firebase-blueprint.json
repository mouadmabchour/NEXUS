{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A digital tool or software service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "affiliateUrl": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "number" },
        "features": { "type": "array" },
        "isFeatured": { "type": "boolean" },
        "isNew": { "type": "boolean" },
        "bestFor": { "type": "string" }
      },
      "required": ["id", "name", "tagline", "description", "price", "affiliateUrl", "category", "image"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categorization",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["id", "name", "icon", "description"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Review": {
      "title": "Review",
      "description": "Expert or user review of a product",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "rating": { "type": "number" },
        "pros": { "type": "array" },
        "cons": { "type": "array" },
        "verdict": { "type": "string" },
        "image": { "type": "string" }
      }
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "Educational or news content",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "author": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "readTime": { "type": "string" }
      }
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A support chat session between a guest/user and AI/Admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed", "archived"] },
        "lastMessageAt": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "number" },
        "customerEmail": { "type": "string" },
        "customerName": { "type": "string" }
      },
      "required": ["id", "userId", "status", "lastMessageAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a support conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderRole": { "type": "string", "enum": ["user", "ai", "admin"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "senderId", "senderRole", "text", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "customerName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "zip": { "type": "string" },
        "country": { "type": "string" },
        "subtotal": { "type": "number" },
        "shippingFee": { "type": "number" },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["card", "paypal", "cod"] },
        "status": { "type": "string", "enum": ["pending", "confirmed", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "customerName", "email", "phone", "address", "city", "zip", "country", "total", "status", "createdAt"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Collection of digital products"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    },
    "blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Blog and educational content"
    },
    "conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Support conversations"
    },
    "conversations/{conversationId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a conversation"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
